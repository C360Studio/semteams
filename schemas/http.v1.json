{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http.v1.json",
  "type": "object",
  "title": "http Configuration",
  "description": "HTTP gateway for bidirectional NATS request/reply",
  "properties": {
    "cors_origins": {
      "type": "array",
      "description": "Allowed origins (required for CORS)",
      "items": {
        "type": "string"
      },
      "category": "advanced"
    },
    "enable_cors": {
      "type": "boolean",
      "description": "Enable CORS",
      "category": "advanced"
    },
    "max_request_size": {
      "type": "number",
      "description": "Max request size (bytes)",
      "category": "advanced"
    },
    "routes": {
      "type": "array",
      "description": "Route mappings",
      "items": {
        "type": "string"
      },
      "category": "basic"
    }
  },
  "required": [],
  "x-component-metadata": {
    "name": "http",
    "type": "gateway",
    "protocol": "http",
    "domain": "network",
    "version": "0.1.0"
  }
}