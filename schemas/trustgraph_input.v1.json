{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "trustgraph_input.v1.json",
  "type": "object",
  "title": "trustgraph_input Configuration",
  "description": "Imports entities from TrustGraph knowledge graph via REST API",
  "properties": {
    "api_key": {
      "type": "string",
      "description": "API key for TrustGraph (optional)"
    },
    "api_key_env": {
      "type": "string",
      "description": "Env var containing API key"
    },
    "collections": {
      "type": "array",
      "description": "TrustGraph collections to import from",
      "items": {
        "type": "string"
      }
    },
    "endpoint": {
      "type": "string",
      "description": "TrustGraph API base URL",
      "default": "http://localhost:8088"
    },
    "kg_core_ids": {
      "type": "array",
      "description": "Specific knowledge core IDs to import",
      "items": {
        "type": "string"
      }
    },
    "limit": {
      "type": "number",
      "description": "Max triples per poll",
      "default": 1000,
      "minimum": 1,
      "maximum": 10000
    },
    "poll_interval": {
      "type": "string",
      "description": "Polling interval (e.g. 30s 5m)",
      "default": "60s"
    },
    "ports": {
      "type": "string",
      "description": "Port configuration",
      "category": "basic"
    },
    "predicate_filter": {
      "type": "array",
      "description": "Predicate URIs to include (empty = all)",
      "items": {
        "type": "string"
      }
    },
    "source": {
      "type": "string",
      "description": "Source identifier for imported triples",
      "default": "trustgraph"
    },
    "subject_filter": {
      "type": "string",
      "description": "URI prefix filter for subjects"
    },
    "timeout": {
      "type": "string",
      "description": "HTTP request timeout",
      "default": "30s"
    },
    "vocab": {
      "type": "object",
      "description": "Vocabulary translation settings",
      "properties": {
        "default_org": {
          "type": "string",
          "description": "default_org"
        },
        "default_uri_base": {
          "type": "string",
          "description": "default_uri_base"
        },
        "org_mappings": {
          "type": "object",
          "description": "org_mappings"
        },
        "predicate_mappings": {
          "type": "object",
          "description": "predicate_mappings"
        },
        "uri_mappings": {
          "type": "object",
          "description": "uri_mappings"
        }
      }
    }
  },
  "required": [],
  "x-component-metadata": {
    "name": "trustgraph_input",
    "type": "input",
    "protocol": "trustgraph",
    "domain": "bridge",
    "version": "1.0.0"
  }
}