{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "github_webhook.v1.json",
  "type": "object",
  "title": "github_webhook Configuration",
  "description": "GitHub webhook receiver for issue and PR events",
  "properties": {
    "event_filter": {
      "type": "array",
      "description": "GitHub event types to accept (issues;pull_request;pull_request_review;issue_comment)",
      "items": {
        "type": "string"
      },
      "category": "basic"
    },
    "http_port": {
      "type": "number",
      "description": "HTTP port for webhook receiver",
      "default": 8090,
      "category": "basic"
    },
    "path": {
      "type": "string",
      "description": "Webhook endpoint path",
      "default": "/github/webhook",
      "category": "basic"
    },
    "ports": {
      "type": "string",
      "description": "Port configuration",
      "category": "basic"
    },
    "repo_allowlist": {
      "type": "array",
      "description": "Repositories to process (owner/repo format)",
      "items": {
        "type": "string"
      },
      "category": "basic"
    }
  },
  "required": [],
  "x-component-metadata": {
    "name": "github_webhook",
    "type": "input",
    "protocol": "http",
    "domain": "github",
    "version": "1.0.0"
  }
}