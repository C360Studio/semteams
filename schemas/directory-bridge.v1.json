{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "directory-bridge.v1.json",
  "type": "object",
  "title": "directory-bridge Configuration",
  "description": "Registers agents with AGNTCY directories using OASF records",
  "properties": {
    "consumer_name_suffix": {
      "type": "string",
      "description": "Suffix for consumer names",
      "category": "advanced"
    },
    "delete_consumer_on_stop": {
      "type": "boolean",
      "description": "Delete consumers on Stop",
      "default": false,
      "category": "advanced"
    },
    "directory_url": {
      "type": "string",
      "description": "AGNTCY directory service URL",
      "category": "basic"
    },
    "heartbeat_interval": {
      "type": "string",
      "description": "Heartbeat interval",
      "default": "30s",
      "category": "basic"
    },
    "identity_provider": {
      "type": "string",
      "description": "Identity provider type",
      "default": "local",
      "category": "basic"
    },
    "oasf_kv_bucket": {
      "type": "string",
      "description": "KV bucket for OASF records",
      "default": "OASF_RECORDS",
      "category": "basic"
    },
    "ports": {
      "type": "string",
      "description": "Port configuration",
      "category": "basic"
    },
    "registration_ttl": {
      "type": "string",
      "description": "Registration time-to-live",
      "default": "5m",
      "category": "basic"
    },
    "retry_count": {
      "type": "number",
      "description": "Number of registration retries",
      "default": 3,
      "category": "advanced"
    },
    "retry_delay": {
      "type": "string",
      "description": "Initial retry delay",
      "default": "1s",
      "category": "advanced"
    }
  },
  "required": [],
  "x-component-metadata": {
    "name": "directory-bridge",
    "type": "output",
    "protocol": "agntcy",
    "domain": "agntcy",
    "version": "1.0.0"
  }
}