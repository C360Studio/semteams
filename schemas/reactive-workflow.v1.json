{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "reactive-workflow.v1.json",
  "type": "object",
  "title": "reactive-workflow Configuration",
  "description": "Reactive workflow engine using KV watch and subject triggers with typed Go conditions and actions",
  "properties": {
    "callback_stream_name": {
      "type": "string",
      "description": "JetStream stream name for callback messages",
      "default": "WORKFLOW_CALLBACKS",
      "category": "advanced"
    },
    "cleanup_interval": {
      "type": "string",
      "description": "How often to run cleanup of completed executions",
      "default": "1h",
      "category": "advanced"
    },
    "cleanup_retention": {
      "type": "string",
      "description": "How long to retain completed executions before cleanup",
      "default": "24h",
      "category": "advanced"
    },
    "consumer_name_prefix": {
      "type": "string",
      "description": "Prefix for NATS consumer names",
      "category": "advanced"
    },
    "default_max_iterations": {
      "type": "number",
      "description": "Default max iterations for loop workflows",
      "default": 10,
      "minimum": 1,
      "maximum": 100,
      "category": "basic"
    },
    "default_timeout": {
      "type": "string",
      "description": "Default timeout for workflows (e.g. 10m)",
      "default": "10m",
      "category": "basic"
    },
    "enable_metrics": {
      "type": "boolean",
      "description": "Enable Prometheus metrics",
      "default": true,
      "category": "advanced"
    },
    "event_stream_name": {
      "type": "string",
      "description": "JetStream stream name for workflow events",
      "default": "WORKFLOW_EVENTS",
      "category": "advanced"
    },
    "ports": {
      "type": "string",
      "description": "Port configuration for workflow inputs and outputs",
      "category": "basic"
    },
    "state_bucket": {
      "type": "string",
      "description": "NATS KV bucket for workflow execution state",
      "default": "REACTIVE_WORKFLOW_STATE",
      "category": "advanced"
    },
    "task_timeout_default": {
      "type": "string",
      "description": "Default timeout for async tasks",
      "default": "5m",
      "category": "advanced"
    }
  },
  "required": [
    "state_bucket",
    "callback_stream_name",
    "event_stream_name"
  ],
  "x-component-metadata": {
    "name": "reactive-workflow",
    "type": "processor",
    "protocol": "nats",
    "domain": "agentic",
    "version": "1.0.0"
  }
}