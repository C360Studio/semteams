{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "file_input.v1.json",
  "type": "object",
  "title": "file_input Configuration",
  "description": "File input component for reading JSONL/JSON files and publishing to NATS",
  "properties": {
    "format": {
      "type": "string",
      "description": "File format (jsonl or json)",
      "default": "jsonl"
    },
    "interval": {
      "type": "string",
      "description": "Delay between lines",
      "default": "10ms"
    },
    "ports": {
      "type": "string",
      "description": "Port configuration",
      "category": "basic"
    }
  },
  "required": [],
  "x-component-metadata": {
    "name": "file_input",
    "type": "input",
    "protocol": "file",
    "domain": "data",
    "version": "1.0.0"
  }
}