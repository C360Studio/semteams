{
  "$defs": {
    "ActionDef": {
      "properties": {
        "depth": {
          "type": "integer"
        },
        "entities": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "entity": {
          "type": "string"
        },
        "fail_fast": {
          "type": "boolean"
        },
        "include": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "model": {
          "type": "string"
        },
        "payload": {
          "items": {
            "minimum": 0,
            "type": "integer"
          },
          "type": "array"
        },
        "prompt": {
          "type": "string"
        },
        "relationships": {
          "type": "boolean"
        },
        "role": {
          "type": "string"
        },
        "state": {
          "items": {
            "minimum": 0,
            "type": "integer"
          },
          "type": "array"
        },
        "subject": {
          "type": "string"
        },
        "task_id": {
          "type": "string"
        },
        "timeout": {
          "type": "string"
        },
        "tools": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "type": {
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "type": "object"
    },
    "ConditionDef": {
      "properties": {
        "field": {
          "type": "string"
        },
        "operator": {
          "type": "string"
        },
        "value": {}
      },
      "required": [
        "field",
        "operator"
      ],
      "type": "object"
    },
    "Definition": {
      "properties": {
        "description": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "id": {
          "type": "string"
        },
        "max_iterations": {
          "type": "integer"
        },
        "name": {
          "type": "string"
        },
        "on_complete": {
          "items": {
            "$ref": "#/$defs/ActionDef"
          },
          "type": "array"
        },
        "on_fail": {
          "items": {
            "$ref": "#/$defs/ActionDef"
          },
          "type": "array"
        },
        "steps": {
          "items": {
            "$ref": "#/$defs/StepDef"
          },
          "type": "array"
        },
        "timeout": {
          "type": "string"
        },
        "trigger": {
          "$ref": "#/$defs/TriggerDef"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "name",
        "enabled",
        "trigger",
        "steps"
      ],
      "type": "object"
    },
    "InputRef": {
      "properties": {
        "from": {
          "type": "string"
        },
        "interface": {
          "type": "string"
        }
      },
      "required": [
        "from"
      ],
      "type": "object"
    },
    "OutputDef": {
      "properties": {
        "interface": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "StepDef": {
      "properties": {
        "action": {
          "$ref": "#/$defs/ActionDef"
        },
        "aggregator": {
          "type": "string"
        },
        "condition": {
          "$ref": "#/$defs/ConditionDef",
          "nullable": true
        },
        "inputs": {
          "additionalProperties": {
            "$ref": "#/$defs/InputRef"
          },
          "type": "object"
        },
        "name": {
          "type": "string"
        },
        "on_fail": {
          "type": "string"
        },
        "on_success": {
          "type": "string"
        },
        "outputs": {
          "additionalProperties": {
            "$ref": "#/$defs/OutputDef"
          },
          "type": "object"
        },
        "steps": {
          "items": {
            "$ref": "#/$defs/StepDef"
          },
          "type": "array"
        },
        "timeout": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "wait": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "TriggerDef": {
      "properties": {
        "subject": {
          "type": "string"
        }
      },
      "required": [
        "subject"
      ],
      "type": "object"
    }
  },
  "$id": "workflow-definition.v1.json",
  "$ref": "#/$defs/Definition",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Schema for SemStreams workflow definitions (ADR-020)",
  "title": "Workflow Definition"
}