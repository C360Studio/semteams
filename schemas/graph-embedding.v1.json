{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "graph-embedding.v1.json",
  "type": "object",
  "title": "graph-embedding Configuration",
  "description": "Graph entity embedding generation processor",
  "properties": {
    "batch_size": {
      "type": "number",
      "description": "Batch size for embedding generation",
      "category": "advanced"
    },
    "cache_ttl": {
      "type": "string",
      "description": "Cache TTL for embeddings",
      "category": "advanced"
    },
    "embedder_type": {
      "type": "string",
      "description": "Embedder type (bm25 or http)",
      "category": "basic"
    },
    "embedder_url": {
      "type": "string",
      "description": "URL for HTTP embedder (required if embedder_type is http)",
      "category": "basic"
    },
    "ports": {
      "type": "string",
      "description": "Port configuration",
      "category": "basic"
    }
  },
  "required": [],
  "x-component-metadata": {
    "name": "graph-embedding",
    "type": "processor",
    "protocol": "nats",
    "domain": "graph",
    "version": "1.0.0"
  }
}