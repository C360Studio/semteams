{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "graph-embedding.v1.json",
  "type": "object",
  "title": "graph-embedding Configuration",
  "description": "Graph entity embedding generation processor",
  "properties": {
    "batch_size": {
      "type": "number",
      "description": "Batch size for embedding generation",
      "category": "advanced"
    },
    "cache_ttl": {
      "type": "string",
      "description": "Cache TTL for embeddings (e.g. 15m or 1h)",
      "category": "advanced"
    },
    "embedder_type": {
      "type": "string",
      "description": "Embedder type (bm25 or http). HTTP requires model registry with embedding capability",
      "category": "basic"
    },
    "ports": {
      "type": "string",
      "description": "Port configuration",
      "category": "basic"
    },
    "startup_attempts": {
      "type": "number",
      "description": "Max attempts to wait for dependencies at startup",
      "category": "advanced"
    },
    "startup_interval_ms": {
      "type": "number",
      "description": "Interval between startup attempts in milliseconds",
      "category": "advanced"
    },
    "text_suffixes": {
      "type": "array",
      "description": "Predicate suffixes to extract for embedding (e.g. .source_code .signature). Defaults to common text predicates",
      "items": {
        "type": "string"
      },
      "category": "advanced"
    }
  },
  "required": [],
  "x-component-metadata": {
    "name": "graph-embedding",
    "type": "processor",
    "protocol": "nats",
    "domain": "graph",
    "version": "1.0.0"
  }
}