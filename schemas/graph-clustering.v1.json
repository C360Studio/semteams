{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "graph-clustering.v1.json",
  "type": "object",
  "title": "graph-clustering Configuration",
  "description": "Graph community detection and clustering processor",
  "properties": {
    "batch_size": {
      "type": "number",
      "description": "Event count threshold for triggering detection",
      "category": "basic"
    },
    "detection_interval": {
      "type": "string",
      "description": "Interval between community detection runs",
      "category": "basic"
    },
    "enable_llm": {
      "type": "boolean",
      "description": "Enable LLM-based community summarization",
      "category": "advanced"
    },
    "llm_endpoint": {
      "type": "string",
      "description": "URL for LLM endpoint (required if enable_llm is true)",
      "category": "advanced"
    },
    "max_iterations": {
      "type": "number",
      "description": "Maximum iterations for LPA algorithm",
      "category": "advanced"
    },
    "min_community_size": {
      "type": "number",
      "description": "Minimum number of entities to form a community",
      "category": "advanced"
    },
    "ports": {
      "type": "string",
      "description": "Port configuration",
      "category": "basic"
    }
  },
  "required": [],
  "x-component-metadata": {
    "name": "graph-clustering",
    "type": "processor",
    "protocol": "nats",
    "domain": "graph",
    "version": "1.0.0"
  }
}