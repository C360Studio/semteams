{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentic-dispatch.v1.json",
  "type": "object",
  "title": "agentic-dispatch Configuration",
  "description": "Routes user messages to agentic loops with command parsing and permissions",
  "properties": {
    "auto_continue": {
      "type": "boolean",
      "description": "Automatically continue last active loop",
      "default": true,
      "category": "basic"
    },
    "classification_model": {
      "type": "string",
      "description": "Model endpoint or capability name for intent classification",
      "default": "default",
      "category": "advanced"
    },
    "consumer_name_suffix": {
      "type": "string",
      "description": "Suffix appended to consumer names for uniqueness",
      "category": "advanced"
    },
    "default_role": {
      "type": "string",
      "description": "Default role for new tasks",
      "default": "general",
      "category": "basic"
    },
    "delete_consumer_on_stop": {
      "type": "boolean",
      "description": "Delete durable consumers on Stop (use for tests only)",
      "default": false,
      "category": "advanced"
    },
    "enable_intent_classification": {
      "type": "boolean",
      "description": "Enable LLM-assisted intent classification for ambiguous messages",
      "default": false,
      "category": "advanced"
    },
    "permissions": {
      "type": "object",
      "description": "Permission configuration",
      "category": "advanced",
      "properties": {
        "approve": {
          "type": "array",
          "description": "approve",
          "items": {
            "type": "string"
          }
        },
        "cancel_any": {
          "type": "array",
          "description": "cancel_any",
          "items": {
            "type": "string"
          }
        },
        "cancel_own": {
          "type": "boolean",
          "description": "cancel_own"
        },
        "submit_task": {
          "type": "array",
          "description": "submit_task",
          "items": {
            "type": "string"
          }
        },
        "view": {
          "type": "array",
          "description": "view",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "ports": {
      "type": "string",
      "description": "Port configuration for inputs and outputs",
      "category": "basic"
    },
    "stream_name": {
      "type": "string",
      "description": "NATS stream name for user messages",
      "default": "USER",
      "category": "advanced"
    }
  },
  "required": [
    "default_role"
  ],
  "x-component-metadata": {
    "name": "agentic-dispatch",
    "type": "processor",
    "protocol": "jetstream",
    "domain": "agentic",
    "version": "1.0.0"
  }
}