{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "slim-bridge.v1.json",
  "type": "object",
  "title": "slim-bridge Configuration",
  "description": "Receives messages from SLIM groups using MLS encryption",
  "properties": {
    "consumer_name_suffix": {
      "type": "string",
      "description": "Suffix for consumer names",
      "category": "advanced"
    },
    "delete_consumer_on_stop": {
      "type": "boolean",
      "description": "Delete consumers on Stop",
      "default": false,
      "category": "advanced"
    },
    "group_ids": {
      "type": "array",
      "description": "SLIM group IDs to join",
      "items": {
        "type": "string"
      },
      "category": "basic"
    },
    "identity_provider": {
      "type": "string",
      "description": "Identity provider type",
      "default": "local",
      "category": "basic"
    },
    "key_ratchet_interval": {
      "type": "string",
      "description": "MLS key ratchet interval",
      "default": "1h",
      "category": "advanced"
    },
    "max_reconnect_attempts": {
      "type": "number",
      "description": "Maximum reconnection attempts",
      "default": 10,
      "category": "advanced"
    },
    "message_buffer_size": {
      "type": "number",
      "description": "Message buffer size",
      "default": 1000,
      "category": "advanced"
    },
    "ports": {
      "type": "string",
      "description": "Port configuration",
      "category": "basic"
    },
    "reconnect_interval": {
      "type": "string",
      "description": "Reconnection interval",
      "default": "5s",
      "category": "advanced"
    },
    "slim_endpoint": {
      "type": "string",
      "description": "SLIM service endpoint URL",
      "category": "basic"
    }
  },
  "required": [],
  "x-component-metadata": {
    "name": "slim-bridge",
    "type": "input",
    "protocol": "slim",
    "domain": "agntcy",
    "version": "1.0.0"
  }
}