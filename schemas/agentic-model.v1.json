{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentic-model.v1.json",
  "type": "object",
  "title": "agentic-model Configuration",
  "description": "OpenAI-compatible agentic model processor with tool calling support",
  "properties": {
    "consumer_name_suffix": {
      "type": "string",
      "description": "Suffix appended to consumer names for uniqueness",
      "category": "advanced"
    },
    "delete_consumer_on_stop": {
      "type": "boolean",
      "description": "Delete durable consumers on Stop (use for tests only)",
      "default": false,
      "category": "advanced"
    },
    "ports": {
      "type": "string",
      "description": "Port configuration",
      "category": "basic"
    },
    "retry": {
      "type": "object",
      "description": "Retry configuration",
      "category": "advanced",
      "properties": {
        "backoff": {
          "type": "string",
          "description": "Backoff strategy",
          "default": "exponential",
          "enum": [
            "exponential",
            "linear"
          ],
          "category": "advanced"
        },
        "max_attempts": {
          "type": "number",
          "description": "Maximum retry attempts",
          "default": 3,
          "category": "advanced"
        }
      }
    },
    "stream_name": {
      "type": "string",
      "description": "JetStream stream name for agentic messages",
      "default": "AGENT",
      "category": "basic"
    },
    "timeout": {
      "type": "string",
      "description": "Request timeout",
      "default": "120s",
      "category": "advanced"
    }
  },
  "required": [],
  "x-component-metadata": {
    "name": "agentic-model",
    "type": "processor",
    "protocol": "openai",
    "domain": "semantic",
    "version": "0.1.0"
  }
}