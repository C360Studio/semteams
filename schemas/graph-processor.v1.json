{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "graph-processor.v1.json",
  "type": "object",
  "title": "graph-processor Configuration",
  "description": "Graph processor for entity extraction and storage",
  "properties": {
    "clustering": {
      "type": "object",
      "description": "Community detection configuration",
      "category": "advanced"
    },
    "enhancement": {
      "type": "object",
      "description": "Async LLM enhancement for community summaries",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable LLM enhancement worker",
          "default": false
        },
        "workers": {
          "type": "number",
          "description": "Number of concurrent LLM workers",
          "default": 3
        },
        "domain": {
          "type": "string",
          "description": "Domain for prompt selection (e.g., 'iot', 'robotics')",
          "default": "default"
        },
        "llm": {
          "$ref": "#/definitions/llm_config"
        }
      },
      "category": "advanced"
    },
    "consumer_name": {
      "type": "string",
      "description": "JetStream consumer name (durable if set)",
      "category": "advanced"
    },
    "data_manager": {
      "type": "object",
      "description": "Data manager configuration",
      "category": "advanced"
    },
    "indexer": {
      "type": "object",
      "description": "Index manager configuration",
      "category": "advanced"
    },
    "input_subject": {
      "type": "string",
      "description": "NATS subject to subscribe for input messages",
      "default": "events.graph.entity.*",
      "category": "basic"
    },
    "message_handler": {
      "type": "object",
      "description": "Message handler configuration",
      "category": "advanced"
    },
    "querier": {
      "type": "object",
      "description": "Query manager configuration",
      "category": "advanced"
    },
    "queue_size": {
      "type": "number",
      "description": "Worker queue size",
      "default": 10000,
      "category": "basic"
    },
    "stream_name": {
      "type": "string",
      "description": "JetStream stream name for durable consumption",
      "category": "advanced"
    },
    "workers": {
      "type": "number",
      "description": "Number of worker goroutines",
      "default": 10,
      "category": "basic"
    }
  },
  "required": [],
  "definitions": {
    "llm_config": {
      "type": "object",
      "description": "LLM service configuration for OpenAI-compatible APIs",
      "properties": {
        "provider": {
          "type": "string",
          "description": "LLM provider type",
          "enum": ["openai", "local", "none"],
          "default": "openai"
        },
        "base_url": {
          "type": "string",
          "description": "Base URL for OpenAI-compatible API (e.g., http://shimmy:8080/v1)",
          "format": "uri"
        },
        "model": {
          "type": "string",
          "description": "Model identifier (e.g., mistral-7b-instruct, gpt-4)",
          "default": "mistral-7b-instruct-v0.2"
        },
        "api_key": {
          "type": "string",
          "description": "API key (optional for local deployments)",
          "x-sensitive": true
        },
        "timeout_seconds": {
          "type": "number",
          "description": "Request timeout in seconds",
          "default": 30
        },
        "max_retries": {
          "type": "number",
          "description": "Maximum retry attempts",
          "default": 3
        },
        "prompts_file": {
          "type": "string",
          "description": "Path to custom prompts JSON file"
        },
        "domain": {
          "type": "string",
          "description": "Domain for prompt selection",
          "default": "default"
        }
      },
      "required": ["base_url", "model"]
    }
  },
  "x-component-metadata": {
    "name": "graph-processor",
    "type": "processor",
    "protocol": "graph",
    "domain": "semantic",
    "version": "1.0.0"
  }
}