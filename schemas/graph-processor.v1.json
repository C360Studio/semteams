{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "graph-processor.v1.json",
  "type": "object",
  "title": "graph-processor Configuration",
  "description": "Graph processor for entity extraction and storage",
  "properties": {
    "clustering": {
      "type": "object",
      "description": "Community detection configuration",
      "category": "advanced"
    },
    "consumer_name": {
      "type": "string",
      "description": "JetStream consumer name (durable if set)",
      "category": "advanced"
    },
    "data_manager": {
      "type": "object",
      "description": "Data manager configuration",
      "category": "advanced"
    },
    "indexer": {
      "type": "object",
      "description": "Index manager configuration",
      "category": "advanced"
    },
    "input_subject": {
      "type": "string",
      "description": "NATS subject to subscribe for input messages",
      "default": "events.graph.entity.*",
      "category": "basic"
    },
    "input_subjects": {
      "type": "array",
      "description": "Multiple NATS subjects to subscribe (derives streams from convention)",
      "items": {
        "type": "string"
      },
      "category": "basic"
    },
    "message_handler": {
      "type": "object",
      "description": "Message handler configuration",
      "category": "advanced"
    },
    "querier": {
      "type": "object",
      "description": "Query manager configuration",
      "category": "advanced"
    },
    "queue_size": {
      "type": "number",
      "description": "Worker queue size",
      "default": 10000,
      "category": "basic"
    },
    "stream_name": {
      "type": "string",
      "description": "JetStream stream name for durable consumption (deprecated: use input_subjects)",
      "category": "advanced"
    },
    "stream_subjects": {
      "type": "array",
      "description": "JetStream stream subjects (defaults to input_subject pattern)",
      "items": {
        "type": "string"
      },
      "category": "advanced"
    },
    "workers": {
      "type": "number",
      "description": "Number of worker goroutines",
      "default": 10,
      "category": "basic"
    }
  },
  "required": [],
  "x-component-metadata": {
    "name": "graph-processor",
    "type": "processor",
    "protocol": "graph",
    "domain": "semantic",
    "version": "1.0.0"
  }
}