{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "file.v1.json",
  "type": "object",
  "title": "file Configuration",
  "description": "File output for writing messages to disk in JSON, JSONL, or raw format",
  "properties": {
    "append": {
      "type": "boolean",
      "description": "Append mode",
      "category": "advanced"
    },
    "buffer_size": {
      "type": "number",
      "description": "Buffer size",
      "category": "advanced"
    },
    "directory": {
      "type": "string",
      "description": "Output directory",
      "category": "basic"
    },
    "file_prefix": {
      "type": "string",
      "description": "Prefix",
      "category": "basic"
    },
    "format": {
      "type": "string",
      "description": "format",
      "enum": [
        "json",
        "jsonl",
        "raw"
      ],
      "category": "basic"
    },
    "ports": {
      "type": "string",
      "description": "Port configuration",
      "category": "basic"
    }
  },
  "required": [],
  "x-component-metadata": {
    "name": "file",
    "type": "output",
    "protocol": "file",
    "domain": "storage",
    "version": "0.1.0"
  }
}