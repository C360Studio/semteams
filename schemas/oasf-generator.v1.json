{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "oasf-generator.v1.json",
  "type": "object",
  "title": "oasf-generator Configuration",
  "description": "Generates OASF records from agent entity capabilities for AGNTCY directory registration",
  "properties": {
    "consumer_name_suffix": {
      "type": "string",
      "description": "Suffix for consumer names",
      "category": "advanced"
    },
    "default_agent_version": {
      "type": "string",
      "description": "Default agent version for OASF records",
      "default": "1.0.0",
      "category": "advanced"
    },
    "default_authors": {
      "type": "array",
      "description": "Default authors for OASF records",
      "items": {
        "type": "string"
      },
      "category": "advanced"
    },
    "delete_consumer_on_stop": {
      "type": "boolean",
      "description": "Delete consumers on Stop",
      "default": false,
      "category": "advanced"
    },
    "entity_kv_bucket": {
      "type": "string",
      "description": "KV bucket for entity states",
      "default": "ENTITY_STATES",
      "category": "basic"
    },
    "generation_debounce": {
      "type": "string",
      "description": "Debounce duration for generation",
      "default": "1s",
      "category": "advanced"
    },
    "include_extensions": {
      "type": "boolean",
      "description": "Include SemStreams extensions",
      "default": true,
      "category": "advanced"
    },
    "oasf_kv_bucket": {
      "type": "string",
      "description": "KV bucket for OASF records",
      "default": "OASF_RECORDS",
      "category": "basic"
    },
    "ports": {
      "type": "string",
      "description": "Port configuration",
      "category": "basic"
    },
    "stream_name": {
      "type": "string",
      "description": "JetStream stream name for entity events",
      "default": "ENTITY",
      "category": "basic"
    },
    "watch_pattern": {
      "type": "string",
      "description": "Key pattern to watch for entity changes",
      "default": "\u003e",
      "category": "advanced"
    }
  },
  "required": [],
  "x-component-metadata": {
    "name": "oasf-generator",
    "type": "processor",
    "protocol": "oasf",
    "domain": "agntcy",
    "version": "1.0.0"
  }
}