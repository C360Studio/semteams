{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "a2a-adapter.v1.json",
  "type": "object",
  "title": "a2a-adapter Configuration",
  "description": "Receives A2A task requests from external agents",
  "properties": {
    "agent_card_path": {
      "type": "string",
      "description": "Path for agent card endpoint",
      "default": "/.well-known/agent.json",
      "category": "basic"
    },
    "consumer_name_suffix": {
      "type": "string",
      "description": "Suffix for consumer names",
      "category": "advanced"
    },
    "delete_consumer_on_stop": {
      "type": "boolean",
      "description": "Delete consumers on Stop",
      "default": false,
      "category": "advanced"
    },
    "listen_address": {
      "type": "string",
      "description": "HTTP listen address",
      "default": ":8080",
      "category": "basic"
    },
    "max_concurrent_tasks": {
      "type": "number",
      "description": "Maximum concurrent tasks",
      "default": 10,
      "category": "advanced"
    },
    "oasf_bucket": {
      "type": "string",
      "description": "OASF records KV bucket",
      "default": "OASF_RECORDS",
      "category": "advanced"
    },
    "ports": {
      "type": "string",
      "description": "Port configuration",
      "category": "basic"
    },
    "request_timeout": {
      "type": "string",
      "description": "Request processing timeout",
      "default": "30s",
      "category": "advanced"
    },
    "slim_group_id": {
      "type": "string",
      "description": "SLIM group for A2A",
      "category": "advanced"
    },
    "transport": {
      "type": "string",
      "description": "A2A transport type",
      "default": "http",
      "category": "basic"
    }
  },
  "required": [],
  "x-component-metadata": {
    "name": "a2a-adapter",
    "type": "input",
    "protocol": "a2a",
    "domain": "agntcy",
    "version": "1.0.0"
  }
}