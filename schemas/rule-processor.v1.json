{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "rule-processor.v1.json",
  "type": "object",
  "title": "rule-processor Configuration",
  "description": "Rule execution processor",
  "properties": {
    "alert_cooldown_period": {
      "type": "string",
      "description": "Minimum time between repeated alerts (e.g. '2m')",
      "default": "2m",
      "category": "advanced"
    },
    "buffer_window_size": {
      "type": "string",
      "description": "Time window for message buffering (e.g. '10m')",
      "default": "10m",
      "category": "advanced"
    },
    "enable_graph_integration": {
      "type": "boolean",
      "description": "Enable graph entity creation from rules",
      "default": true,
      "category": "basic"
    },
    "entity_watch_patterns": {
      "type": "array",
      "description": "NATS KV patterns to watch for entity changes (e.g. 'telemetry.robotics.\u003e')",
      "items": {
        "type": "string"
      },
      "category": "advanced"
    },
    "inline_rules": {
      "type": "array",
      "description": "Inline rule definitions (alternative to files)",
      "items": {
        "type": "string"
      },
      "category": "basic"
    },
    "ports": {
      "type": "string",
      "description": "Port configuration for inputs (KV watch: ENTITY_STATES PREDICATE_INDEX) and outputs (NATS: control commands)",
      "category": "basic"
    },
    "rules": {
      "type": "object",
      "description": "Dynamic rule definitions (rules.{rule_id} pattern)",
      "default": {},
      "category": "advanced"
    },
    "rules_files": {
      "type": "array",
      "description": "Paths to JSON rule definition files",
      "default": [
        "[]"
      ],
      "items": {
        "type": "string"
      },
      "category": "basic"
    }
  },
  "required": [],
  "x-component-metadata": {
    "name": "rule-processor",
    "type": "processor",
    "protocol": "rule",
    "domain": "semantic",
    "version": "1.0.0"
  }
}