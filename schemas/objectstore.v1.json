{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "objectstore.v1.json",
  "type": "object",
  "title": "objectstore Configuration",
  "description": "NATS ObjectStore component for immutable message storage",
  "properties": {
    "bucket_name": {
      "type": "string",
      "description": "NATS ObjectStore bucket name",
      "default": "MESSAGES",
      "category": "basic"
    },
    "ports": {
      "type": "string",
      "description": "Port configuration for inputs and outputs",
      "category": "basic"
    }
  },
  "required": [],
  "x-component-metadata": {
    "name": "objectstore",
    "type": "storage",
    "protocol": "objectstore",
    "domain": "storage",
    "version": "1.0.0"
  }
}