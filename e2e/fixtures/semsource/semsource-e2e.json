{
  "namespace": "e2e",
  "flow": {
    "outputs": [
      {
        "name": "graph_stream",
        "type": "network",
        "subject": "http://0.0.0.0:7890/graph"
      }
    ],
    "delivery_mode": "at-least-once",
    "ack_timeout": "5s"
  },
  "sources": [
    {
      "type": "ast",
      "path": "/data/fixture/src",
      "language": "go",
      "watch": false
    },
    {
      "type": "docs",
      "paths": ["/data/fixture/README.md"],
      "watch": false
    },
    {
      "type": "config",
      "paths": ["/data/fixture/go.mod", "/data/fixture/Dockerfile"],
      "watch": false
    }
  ]
}
