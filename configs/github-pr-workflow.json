{
  "version": "1.1.0",
  "platform": {
    "org": "c360",
    "id": "semstreams-github-workflow",
    "type": "github-pr-workflow",
    "region": "local",
    "instance_id": "github-001",
    "environment": "production"
  },
  "tier": "agentic",
  "nats": {
    "urls": ["nats://localhost:4222"]
  },
  "model_registry": {
    "endpoints": {
      "default": {
        "provider": "${LLM_PROVIDER:-openai}",
        "url": "${LLM_API_URL:-https://api.openai.com/v1}",
        "model": "${LLM_MODEL:-gpt-4o}",
        "max_tokens": 8192,
        "supports_tools": true,
        "tool_format": "${LLM_TOOL_FORMAT:-openai}",
        "api_key_env": "${LLM_API_KEY_ENV:-OPENAI_API_KEY}"
      }
    },
    "defaults": {
      "model": "default"
    }
  },
  "services": {
    "service-manager": {
      "name": "service-manager",
      "enabled": true,
      "config": {
        "http_port": 8080,
        "server_info": {
          "title": "SemStreams GitHub PR Workflow",
          "description": "Adversarial issue-to-PR automation",
          "version": "0.1.0"
        }
      }
    },
    "component-manager": {
      "name": "component-manager",
      "enabled": true,
      "config": {}
    },
    "metrics": {
      "name": "metrics",
      "enabled": true,
      "config": {
        "port": 9090,
        "path": "/metrics"
      }
    }
  },
  "components": {
    "github-webhook": {
      "type": "input",
      "name": "github_webhook",
      "enabled": true,
      "config": {
        "http_port": 8090,
        "path": "/github/webhook",
        "webhook_secret_env": "GITHUB_WEBHOOK_SECRET",
        "repo_allowlist": [],
        "event_filter": ["issues", "pull_request", "pull_request_review", "issue_comment"],
        "ports": {
          "outputs": [
            {"name": "issue_events", "subject": "github.event.issue", "type": "jetstream", "stream": "GITHUB"},
            {"name": "pr_events", "subject": "github.event.pr", "type": "jetstream", "stream": "GITHUB"},
            {"name": "review_events", "subject": "github.event.review", "type": "jetstream", "stream": "GITHUB"},
            {"name": "comment_events", "subject": "github.event.comment", "type": "jetstream", "stream": "GITHUB"}
          ]
        }
      }
    },
    "teams-loop": {
      "type": "processor",
      "name": "teams-loop",
      "enabled": true,
      "config": {
        "max_iterations": 25,
        "timeout": "300s",
        "loops_bucket": "AGENT_LOOPS",
        "ports": {
          "inputs": [
            {"name": "task_input", "subject": "agent.task.>", "type": "jetstream", "stream": "AGENT"}
          ],
          "outputs": [
            {"name": "request_output", "subject": "agent.request", "type": "nats"},
            {"name": "complete_output", "subject": "agent.complete", "type": "nats"}
          ]
        }
      }
    },
    "teams-model": {
      "type": "processor",
      "name": "teams-model",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {"name": "request_input", "subject": "agent.request.>", "type": "jetstream", "stream": "AGENT"}
          ],
          "outputs": [
            {"name": "response_output", "subject": "agent.response", "type": "nats"}
          ]
        }
      }
    },
    "teams-tools": {
      "type": "processor",
      "name": "teams-tools",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {"name": "tool_input", "subject": "tool.execute.>", "type": "jetstream", "stream": "AGENT"}
          ],
          "outputs": [
            {"name": "tool_output", "subject": "tool.result", "type": "nats"}
          ]
        }
      }
    },
    "pr-workflow-spawner": {
      "type": "processor",
      "name": "pr-workflow-spawner",
      "enabled": true,
      "config": {
        "model": "default",
        "token_budget": 500000,
        "max_review_cycles": 3,
        "ports": {
          "inputs": [
            {"name": "github_events", "subject": "github.event.issue", "type": "jetstream", "stream": "GITHUB"},
            {"name": "agent_completions", "subject": "agent.complete.*", "type": "jetstream", "stream": "AGENT"}
          ],
          "outputs": [
            {"name": "agent_tasks", "subject": "agent.task", "type": "jetstream", "stream": "AGENT"},
            {"name": "triple_mutations", "subject": "graph.mutation.triple.add", "type": "nats"}
          ]
        }
      }
    },
    "rule-processor": {
      "type": "processor",
      "name": "rule-processor",
      "enabled": true,
      "config": {
        "rules_dir": "configs/rules/github-pr-workflow",
        "entity": {
          "pattern": "*.github.repo.*.workflow.*",
          "watch_buckets": ["ENTITY_STATES"]
        },
        "ports": {
          "inputs": [
            {"name": "entity_states", "subject": "ENTITY_STATES.>", "type": "kv-watch", "bucket": "ENTITY_STATES"}
          ],
          "outputs": [
            {"name": "triple_mutations", "subject": "graph.mutation.triple", "type": "nats"},
            {"name": "workflow_events", "subject": "github.workflow", "type": "nats"}
          ]
        }
      }
    },
    "graph-ingest": {
      "type": "processor",
      "name": "graph-ingest",
      "enabled": true,
      "config": {
        "entity_bucket": "ENTITY_STATES",
        "ports": {
          "inputs": [
            {"name": "triple_add", "subject": "graph.mutation.triple.add", "type": "nats"},
            {"name": "triple_remove", "subject": "graph.mutation.triple.remove", "type": "nats"}
          ],
          "outputs": [
            {"name": "entity_events", "subject": "events.graph.entity", "type": "nats"}
          ]
        }
      }
    }
  }
}
