{
  "version": "1.1.0",
  "platform": {
    "org": "c360",
    "id": "semteams-agentic",
    "type": "agentic",
    "region": "local",
    "instance_id": "agentic-001",
    "environment": "development"
  },
  "tier": "agentic",
  "nats": {
    "urls": ["nats://localhost:4222"]
  },
  "model_registry": {
    "endpoints": {
      "claude-haiku": {
        "provider": "anthropic",
        "url": "https://api.anthropic.com/v1",
        "model": "claude-haiku-4-5-20251001",
        "api_key_env": "ANTHROPIC_API_KEY",
        "max_tokens": 200000,
        "supports_tools": true,
        "stream": true,
        "max_concurrent": 10,
        "requests_per_minute": 200
      },
      "claude-sonnet": {
        "provider": "anthropic",
        "url": "https://api.anthropic.com/v1",
        "model": "claude-sonnet-4-6",
        "api_key_env": "ANTHROPIC_API_KEY",
        "max_tokens": 200000,
        "supports_tools": true,
        "stream": true,
        "reasoning_effort": "low",
        "max_concurrent": 10,
        "requests_per_minute": 100
      },
      "gemini-flash": {
        "provider": "openai",
        "url": "https://generativelanguage.googleapis.com/v1beta/openai",
        "model": "gemini-2.5-flash",
        "api_key_env": "GEMINI_API_KEY",
        "max_tokens": 1048576,
        "supports_tools": true,
        "tool_format": "openai",
        "stream": true,
        "max_concurrent": 10,
        "requests_per_minute": 200
      }
    },
    "defaults": {
      "model": "claude-haiku"
    }
  },
  "services": {
    "service-manager": {
      "name": "service-manager",
      "enabled": true,
      "config": {
        "http_port": 8080,
        "swagger_ui": true,
        "server_info": {
          "title": "SemTeams Agentic Tier",
          "description": "Agentic components with real LLM providers",
          "version": "0.7.0"
        }
      }
    },
    "component-manager": {
      "name": "component-manager",
      "enabled": true,
      "config": {}
    },
    "metrics": {
      "name": "metrics",
      "enabled": true,
      "config": {
        "port": 9090,
        "path": "/metrics",
        "include_go_metrics": true
      }
    },
    "message-logger": {
      "name": "message-logger",
      "enabled": true,
      "config": {
        "buffer_size": 10000,
        "monitor_subjects": ["teams.>"],
        "enable_kv_query": true,
        "log_level": "INFO"
      }
    },
    "log-forwarder": {
      "name": "log-forwarder",
      "enabled": true,
      "config": {
        "min_level": "DEBUG",
        "exclude_sources": []
      }
    },
    "metrics-forwarder": {
      "name": "metrics-forwarder",
      "enabled": true,
      "config": {
        "push_interval": "5s",
        "include_go_metrics": false,
        "include_proc_metrics": false
      }
    }
  },
  "components": {
    "file_sensors": {
      "type": "input",
      "name": "file_input",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [],
          "outputs": [
            {
              "name": "file_out",
              "subject": "raw.sensor.file",
              "type": "jetstream"
            }
          ]
        },
        "path": "/data/testdata/semantic/sensors.jsonl",
        "format": "jsonl",
        "interval": "10ms",
        "loop": false
      }
    },
    "iot_sensor": {
      "type": "processor",
      "name": "iot_sensor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "sensor_in",
              "subject": "raw.sensor.>",
              "type": "jetstream"
            }
          ],
          "outputs": [
            {
              "name": "sensor_out",
              "subject": "sensor.processed.entity",
              "type": "jetstream",
              "interface": "iot.sensor.v1"
            }
          ]
        },
        "org_id": "c360",
        "platform": "logistics"
      }
    },
    "graph-ingest": {
      "type": "processor",
      "name": "graph-ingest",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "sensor_in",
              "subject": "sensor.processed.entity",
              "type": "jetstream",
              "interface": "iot.sensor.v1",
              "description": "Sensor entity events from IoT processor"
            }
          ],
          "outputs": [
            {
              "name": "entity_states",
              "subject": "ENTITY_STATES",
              "type": "kv-write",
              "description": "Entity state KV bucket"
            }
          ]
        },
        "enable_hierarchy": true
      }
    },
    "rule": {
      "type": "processor",
      "name": "rule-processor",
      "enabled": true,
      "config": {
        "entity_watch_patterns": ["c360.>"],
        "ports": {
          "inputs": [
            {
              "name": "rule_sensor_in",
              "subject": "sensor.processed.entity",
              "type": "jetstream",
              "description": "Sensor entity events"
            }
          ],
          "outputs": [
            {
              "name": "rule_out",
              "subject": "rule.triggered.alert",
              "type": "jetstream"
            },
            {
              "name": "agent_task",
              "subject": "teams.task.*",
              "type": "jetstream",
              "stream_name": "TEAMS",
              "description": "Agent task triggers from rules"
            }
          ]
        },
        "enable_graph_integration": true,
        "graph_event_subject_prefix": "sensor.processed",
        "inline_rules": [
          {
            "id": "temperature-anomaly-agent",
            "type": "expression",
            "name": "Temperature Anomaly Agent Trigger",
            "description": "Triggers an agent when temperature exceeds threshold to analyze sensor data",
            "enabled": true,
            "conditions": [
              {
                "field": "sensor.measurement.fahrenheit",
                "operator": "gte",
                "value": 45.0,
                "required": true
              },
              {
                "field": "sensor.classification.type",
                "operator": "eq",
                "value": "temperature",
                "required": true
              }
            ],
            "logic": "and",
            "cooldown": "30s",
            "on_enter": [
              {
                "type": "publish_agent",
                "subject": "teams.task.temp_anomaly",
                "role": "general",
                "model": "claude-haiku",
                "prompt": "Temperature anomaly detected. Sensor: {{.EntityID}}, Reading: {{.Properties.sensor.measurement.fahrenheit}}F. Use query_entity tool to get full sensor details, then provide assessment and recommendations."
              },
              {
                "type": "publish",
                "subject": "alerts.temperature.anomaly"
              }
            ],
            "on_exit": [],
            "metadata": {
              "severity": "warning",
              "category": "environmental",
              "tier": 0
            }
          }
        ]
      }
    },
    "workflow-processor": {
      "type": "processor",
      "name": "workflow-processor",
      "enabled": true,
      "config": {
        "definitions_bucket": "WORKFLOW_DEFINITIONS",
        "executions_bucket": "WORKFLOW_EXECUTIONS",
        "stream_name": "WORKFLOW",
        "default_timeout": "60s",
        "default_max_iterations": 3,
        "request_timeout": "30s",
        "ports": {
          "inputs": [
            {
              "name": "workflow.trigger",
              "type": "jetstream",
              "subject": "workflow.trigger.>",
              "stream_name": "WORKFLOW",
              "required": true,
              "description": "Workflow trigger events"
            },
            {
              "name": "workflow.step.complete",
              "type": "jetstream",
              "subject": "workflow.step.complete.>",
              "stream_name": "WORKFLOW",
              "required": true,
              "description": "Step completion events from external sources"
            },
            {
              "name": "workflow.step.result",
              "type": "jetstream",
              "subject": "workflow.step.result.>",
              "stream_name": "WORKFLOW",
              "required": true,
              "description": "Async step results from any executor (agentic, HTTP, custom)"
            }
          ],
          "outputs": [
            {
              "name": "workflow.events",
              "type": "jetstream",
              "subject": "workflow.events",
              "stream_name": "WORKFLOW",
              "description": "Workflow lifecycle events"
            },
            {
              "name": "agent.task",
              "type": "jetstream",
              "subject": "teams.task.*",
              "stream_name": "TEAMS",
              "description": "Agent task spawning"
            }
          ],
          "kv_write": [
            {
              "name": "definitions",
              "type": "kv-write",
              "bucket": "WORKFLOW_DEFINITIONS",
              "description": "Workflow definition storage"
            },
            {
              "name": "executions",
              "type": "kv-write",
              "bucket": "WORKFLOW_EXECUTIONS",
              "description": "Workflow execution state storage"
            }
          ]
        }
      }
    },
    "teams-loop": {
      "type": "processor",
      "name": "teams-loop",
      "enabled": true,
      "config": {
        "max_iterations": 5,
        "timeout": "30s",
        "approval_required": ["create_rule", "update_rule", "delete_rule"],
        "stream_name": "TEAMS",
        "loops_bucket": "AGENT_LOOPS",
        "ports": {
          "inputs": [
            {
              "name": "agent.task",
              "type": "jetstream",
              "subject": "teams.task.*",
              "stream_name": "TEAMS",
              "required": true,
              "description": "Agent task requests"
            },
            {
              "name": "agent.response",
              "type": "jetstream",
              "subject": "teams.response.>",
              "stream_name": "TEAMS",
              "required": true,
              "description": "Model responses"
            },
            {
              "name": "tool.result",
              "type": "jetstream",
              "subject": "teams.result.>",
              "stream_name": "TEAMS",
              "required": true,
              "description": "Tool execution results"
            }
          ],
          "outputs": [
            {
              "name": "agent.request",
              "type": "jetstream",
              "subject": "teams.request.*",
              "stream_name": "TEAMS",
              "description": "Model requests"
            },
            {
              "name": "tool.execute",
              "type": "jetstream",
              "subject": "teams.execute.*",
              "stream_name": "TEAMS",
              "description": "Tool execution requests"
            },
            {
              "name": "agent.complete",
              "type": "jetstream",
              "subject": "teams.complete.*",
              "stream_name": "TEAMS",
              "description": "Task completions"
            }
          ],
          "kv_write": [
            {
              "name": "loops",
              "type": "kv-write",
              "bucket": "AGENT_LOOPS",
              "description": "Loop state storage"
            },
            {
              "name": "trajectories",
              "type": "kv-write",
              "bucket": "AGENT_TRAJECTORIES",
              "description": "Trajectory storage"
            }
          ]
        }
      }
    },
    "teams-model": {
      "type": "processor",
      "name": "teams-model",
      "enabled": true,
      "config": {
        "stream_name": "TEAMS",
        "timeout": "30s",
        "retry": {
          "max_attempts": 3,
          "backoff": "exponential"
        },
        "ports": {
          "inputs": [
            {
              "name": "agent.request",
              "type": "jetstream",
              "subject": "teams.request.>",
              "stream_name": "TEAMS",
              "required": true,
              "description": "Agent request input"
            }
          ],
          "outputs": [
            {
              "name": "agent.response",
              "type": "jetstream",
              "subject": "teams.response.*",
              "stream_name": "TEAMS",
              "required": true,
              "description": "Agent response output"
            }
          ]
        }
      }
    },
    "teams-tools": {
      "type": "processor",
      "name": "teams-tools",
      "enabled": true,
      "config": {
        "stream_name": "TEAMS",
        "timeout": "10s",
        "allowed_tools": ["query_entity"],
        "ports": {
          "inputs": [
            {
              "name": "tool.execute",
              "type": "jetstream",
              "subject": "teams.execute.>",
              "stream_name": "TEAMS",
              "required": true,
              "description": "Tool execution requests"
            }
          ],
          "outputs": [
            {
              "name": "tool.result",
              "type": "jetstream",
              "subject": "teams.result.*",
              "stream_name": "TEAMS",
              "required": true,
              "description": "Tool execution results"
            }
          ],
          "kv_read": [
            {
              "name": "entity_states",
              "type": "kv-read",
              "bucket": "ENTITY_STATES",
              "description": "Entity state KV for graph queries"
            }
          ]
        }
      }
    },
    "oasf-generator": {
      "type": "processor",
      "name": "oasf-generator",
      "enabled": true,
      "config": {
        "entity_kv_bucket": "ENTITY_STATES",
        "oasf_kv_bucket": "OASF_RECORDS",
        "watch_pattern": ">",
        "generation_debounce": "500ms",
        "default_agent_version": "1.0.0",
        "default_authors": ["SemStreams"],
        "include_extensions": true,
        "ports": {
          "inputs": [
            {
              "name": "entity_changes",
              "subject": "entity.state.>",
              "type": "kv-watch",
              "required": true,
              "description": "Watch for agent entity state changes"
            }
          ],
          "outputs": [
            {
              "name": "oasf_records",
              "subject": "oasf.record.generated.*",
              "type": "jetstream",
              "stream_name": "OASF",
              "required": true,
              "description": "Generated OASF records"
            }
          ],
          "kv_write": [
            {
              "name": "oasf_kv",
              "type": "kv-write",
              "bucket": "OASF_RECORDS",
              "description": "OASF record storage"
            }
          ]
        }
      }
    },
    "directory-bridge": {
      "type": "output",
      "name": "directory-bridge",
      "enabled": false,
      "config": {
        "directory_url": "http://localhost:8081",
        "heartbeat_interval": "30s",
        "registration_ttl": "5m",
        "identity_provider": "local",
        "oasf_kv_bucket": "OASF_RECORDS",
        "retry_count": 3,
        "retry_delay": "1s",
        "ports": {
          "inputs": [
            {
              "name": "oasf_records",
              "subject": "oasf.record.generated.>",
              "type": "kv-watch",
              "required": true,
              "description": "Watch for generated OASF records"
            }
          ],
          "outputs": [
            {
              "name": "registration_events",
              "subject": "directory.registration.*",
              "type": "jetstream",
              "stream_name": "DIRECTORY",
              "required": false,
              "description": "Registration events"
            }
          ]
        }
      }
    },
    "a2a-adapter": {
      "type": "input",
      "name": "a2a-adapter",
      "enabled": true,
      "config": {
        "transport": "http",
        "listen_address": ":8282",
        "agent_card_path": "/.well-known/agent.json",
        "request_timeout": "30s",
        "max_concurrent_tasks": 10,
        "enable_authentication": false,
        "oasf_bucket": "OASF_RECORDS",
        "ports": {
          "inputs": [],
          "outputs": [
            {
              "name": "task_messages",
              "subject": "teams.task.a2a.*",
              "type": "jetstream",
              "stream_name": "TEAMS",
              "required": true,
              "description": "Task messages to agent dispatch"
            }
          ]
        }
      }
    },
    "otel-exporter": {
      "type": "output",
      "name": "otel-exporter",
      "enabled": false,
      "config": {
        "endpoint": "http://localhost:4318",
        "protocol": "http",
        "service_name": "semstreams-agentic",
        "service_version": "1.0.0",
        "export_traces": true,
        "export_metrics": true,
        "export_logs": false,
        "batch_timeout": "2s",
        "max_batch_size": 100,
        "insecure": true,
        "sampling_rate": 1.0,
        "ports": {
          "inputs": [
            {
              "name": "agent_events",
              "subject": "teams.>",
              "type": "jetstream",
              "stream_name": "TEAMS",
              "required": true,
              "description": "Agent lifecycle events for span collection"
            }
          ],
          "outputs": []
        }
      }
    }
  }
}
