{
  "version": "1.0.0",
  "platform": {
    "org": "c360",
    "id": "semstreams-semantic-basic",
    "type": "semantic-processing",
    "region": "local",
    "instance_id": "semantic-001",
    "environment": "test"
  },
  "nats": {
    "urls": ["nats://localhost:4222"]
  },
  "services": {
    "component-manager": {
      "name": "component-manager",
      "enabled": true,
      "config": {}
    },
    "metrics": {
      "name": "metrics",
      "enabled": true,
      "config": {
        "port": 9090,
        "path": "/metrics",
        "include_go_metrics": true
      }
    },
    "message-logger": {
      "name": "message-logger",
      "enabled": true,
      "config": {
        "buffer_size": 1000,
        "monitor_subjects": ["raw.>", "events.>"],
        "enable_kv_query": true,
        "log_level": "DEBUG",
        "output_to_stdout": true
      }
    }
  },
  "components": {
    "udp": {
      "type": "input",
      "name": "udp",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [],
          "outputs": [
            {
              "name": "udp_out",
              "subject": "raw.udp.messages",
              "type": "nats"
            }
          ]
        },
        "bind": "0.0.0.0",
        "port": 14550,
        "buffer_size": 65536
      }
    },
    "iot_sensor": {
      "type": "processor",
      "name": "iot_sensor",
      "enabled": true,
      "config": {
        "org_id": "c360",
        "platform": "semstreams",
        "ports": {
          "inputs": [
            {
              "name": "sensor_in",
              "subject": "raw.udp.messages",
              "type": "nats"
            }
          ],
          "outputs": [
            {
              "name": "sensor_out",
              "subject": "events.graph.entity.sensor",
              "type": "nats",
              "interface": "domain.iot.sensor.v1"
            }
          ]
        }
      }
    },
    "graph": {
      "type": "processor",
      "name": "graph-processor",
      "enabled": true,
      "config": {
        "workers": 4,
        "queue_size": 1000,
        "input_subject": "events.graph.entity.sensor",
        "stream_name": "GRAPH_EVENTS",
        "consumer_name": "graph-processor",
        "message_handler": {
          "processing_timeout": "5s",
          "max_retries": 3
        },
        "data_manager": {
          "kv_bucket": "graph_entities",
          "kv_options": {
            "max_retries": 10,
            "timeout": "5s"
          }
        },
        "indexer": {
          "indexes": {
            "predicate": true,
            "incoming": true,
            "alias": true,
            "spatial": true,
            "temporal": true
          },
          "buckets": {
            "alias": "ALIAS_INDEX",
            "predicate": "PREDICATE_INDEX",
            "incoming": "INCOMING_INDEX",
            "spatial": "SPATIAL_INDEX",
            "temporal": "TEMPORAL_INDEX"
          }
        },
        "querier": {
          "cache_enabled": true,
          "cache_ttl": "5m",
          "max_cache_size": 1000
        }
      }
    }
  }
}
