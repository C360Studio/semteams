{
  "version": "1.1.0",
  "platform": {
    "org": "c360",
    "id": "semteams-coordinator",
    "type": "agentic-e2e",
    "region": "local",
    "instance_id": "coordinator-001",
    "environment": "test"
  },
  "tier": "agentic",
  "nats": {
    "urls": ["nats://localhost:4222"]
  },
  "streams": {
    "USER": {
      "subjects": ["user.>"],
      "storage": "file",
      "max_age": "1h"
    }
  },
  "model_registry": {
    "endpoints": {
      "general": {
        "provider": "openai",
        "url": "http://mock-llm:8080/v1",
        "model": "mock-model",
        "max_tokens": 4096,
        "supports_tools": true,
        "tool_format": "openai",
        "stream": true
      },
      "fast": {
        "provider": "openai",
        "url": "http://mock-llm:8080/v1",
        "model": "mock-model",
        "max_tokens": 2048,
        "supports_tools": true,
        "tool_format": "openai",
        "stream": false
      }
    },
    "defaults": {
      "model": "general"
    },
    "capabilities": {
      "general": { "preferred": ["general"] },
      "fast": { "preferred": ["fast"] },
      "summarization": { "preferred": ["fast"] }
    }
  },
  "services": {
    "service-manager": {
      "name": "service-manager",
      "enabled": true,
      "config": {
        "http_port": 8080,
        "swagger_ui": true,
        "server_info": {
          "title": "SemTeams Coordinator E2E",
          "description": "Coordinator front-door journey: user chat → coordinator classifies → decide tool writes triple → rule spawns researcher → researcher completes. Exercises the ADR-029 Pattern-B wiring end to end.",
          "version": "1.0.0"
        }
      }
    },
    "component-manager": {
      "name": "component-manager",
      "enabled": true,
      "config": {}
    },
    "metrics": {
      "name": "metrics",
      "enabled": true,
      "config": {
        "port": 9090,
        "path": "/metrics",
        "include_go_metrics": true
      }
    },
    "message-logger": {
      "name": "message-logger",
      "enabled": true,
      "config": {
        "buffer_size": 10000,
        "monitor_subjects": [
          "agent.>",
          "tool.>",
          "user.>",
          "graph.mutation.>"
        ],
        "enable_kv_query": true,
        "log_level": "INFO"
      }
    },
    "flow-builder": {
      "name": "flow-builder",
      "enabled": true,
      "config": {}
    }
  },
  "components": {
    "teams-dispatch": {
      "type": "processor",
      "name": "agentic-dispatch",
      "enabled": true,
      "config": {
        "default_role": "coordinator",
        "default_tools": ["decide", "read_loop_result", "submit_work"],
        "auto_continue": false,
        "stream_name": "USER",
        "permissions": {
          "submit_task": ["*"],
          "view": ["*"],
          "approve": ["*"]
        },
        "ports": {
          "inputs": [
            {"name": "user.message", "type": "jetstream", "subject": "user.message.>", "stream_name": "USER", "required": true, "description": "User messages from any channel"},
            {"name": "agent.complete", "type": "jetstream", "subject": "agent.complete.*", "stream_name": "AGENT", "required": true, "description": "Agent completion events"}
          ],
          "outputs": [
            {"name": "agent.task", "type": "jetstream", "subject": "agent.task.*", "stream_name": "AGENT", "description": "Task submissions to agent loop"},
            {"name": "user.response", "type": "nats", "subject": "user.response.*", "description": "Responses back to users"}
          ]
        }
      }
    },
    "teams-loop": {
      "type": "processor",
      "name": "agentic-loop",
      "enabled": true,
      "config": {
        "max_iterations": 6,
        "timeout": "15s",
        "stream_name": "AGENT",
        "loops_bucket": "AGENT_LOOPS",
        "consumer": {
          "ack_wait": "15s",
          "heartbeat_interval": "10s",
          "max_deliver": 2
        },
        "context": {
          "compact_threshold": 1.0,
          "headroom_ratio": 0.05,
          "headroom_tokens": 100
        },
        "ports": {
          "inputs": [
            {"name": "agent.task", "type": "jetstream", "subject": "agent.task.*", "stream_name": "AGENT", "required": true},
            {"name": "agent.response", "type": "jetstream", "subject": "agent.response.>", "stream_name": "AGENT", "required": true},
            {"name": "tool.result", "type": "jetstream", "subject": "tool.result.>", "stream_name": "TOOL", "required": true}
          ],
          "outputs": [
            {"name": "agent.request", "type": "jetstream", "subject": "agent.request.*", "stream_name": "AGENT"},
            {"name": "tool.execute", "type": "jetstream", "subject": "tool.execute.*", "stream_name": "TOOL"},
            {"name": "agent.complete", "type": "jetstream", "subject": "agent.complete.*", "stream_name": "AGENT"}
          ],
          "kv_write": [
            {"name": "loops", "type": "kv-write", "bucket": "AGENT_LOOPS"},
            {"name": "trajectories", "type": "kv-write", "bucket": "AGENT_TRAJECTORIES"}
          ]
        }
      }
    },
    "agentic-model": {
      "type": "processor",
      "name": "agentic-model",
      "enabled": true,
      "config": {
        "stream_name": "AGENT",
        "timeout": "15s",
        "retry": {
          "max_attempts": 2,
          "backoff": "exponential"
        },
        "ports": {
          "inputs": [
            {"name": "agent.request", "type": "jetstream", "subject": "agent.request.>", "stream_name": "AGENT", "required": true}
          ],
          "outputs": [
            {"name": "agent.response", "type": "jetstream", "subject": "agent.response.*", "stream_name": "AGENT", "required": true}
          ]
        }
      }
    },
    "agentic-tools": {
      "type": "processor",
      "name": "agentic-tools",
      "enabled": true,
      "config": {
        "stream_name": "TOOL",
        "timeout": "10s",
        "allowed_tools": ["web_search", "decide", "read_loop_result", "submit_work"],
        "ports": {
          "inputs": [
            {"name": "tool.execute", "type": "jetstream", "subject": "tool.execute.>", "stream_name": "TOOL", "required": true}
          ],
          "outputs": [
            {"name": "tool.result", "type": "jetstream", "subject": "tool.result.*", "stream_name": "TOOL", "required": true}
          ],
          "kv_read": [
            {"name": "entity_states", "type": "kv-read", "bucket": "ENTITY_STATES"}
          ]
        }
      }
    },
    "rule-processor": {
      "type": "processor",
      "name": "rule-processor",
      "enabled": true,
      "config": {
        "rules_files": [
          "/app/configs/rules/coordinator/01-delegate-research.json"
        ],
        "enable_graph_integration": true,
        "entity_watch_buckets": {
          "ENTITY_STATES": [">"]
        },
        "ports": {
          "inputs": [
            {"name": "entity_states", "subject": "ENTITY_STATES.>", "type": "kv-watch", "bucket": "ENTITY_STATES"}
          ],
          "outputs": [
            {"name": "agent.task", "subject": "agent.task.*", "type": "jetstream", "stream_name": "AGENT", "description": "Spawn agents from rules"},
            {"name": "graph.mutation", "subject": "graph.mutation.*", "type": "nats", "description": "Graph triple mutations"}
          ]
        }
      }
    },
    "graph-ingest": {
      "type": "processor",
      "name": "graph-ingest",
      "enabled": true,
      "config": {
        "enable_hierarchy": true,
        "ports": {
          "inputs": [
            {"name": "graph_mutations", "subject": "graph.mutation.>", "type": "nats"}
          ],
          "outputs": [
            {"name": "entity_states", "subject": "ENTITY_STATES", "type": "kv-write"}
          ]
        }
      }
    }
  }
}
