{
  "version": "1.1.0",
  "platform": {
    "org": "c360",
    "id": "semstreams-tier0-rules",
    "type": "rules-only",
    "region": "local",
    "instance_id": "tier0-001",
    "environment": "test"
  },
  "tier": "rules",
  "nats": {
    "urls": ["nats://localhost:4222"]
  },
  "services": {
    "service-manager": {
      "name": "service-manager",
      "enabled": true,
      "config": {
        "http_port": 8080,
        "swagger_ui": true,
        "server_info": {
          "title": "SemStreams Tier 0 - Rules Only",
          "description": "Stateful rules processing with deterministic graph behavior (no ML inference)",
          "version": "0.7.0"
        }
      }
    },
    "component-manager": {
      "name": "component-manager",
      "enabled": true,
      "config": {}
    },
    "metrics": {
      "name": "metrics",
      "enabled": true,
      "config": {
        "port": 9090,
        "path": "/metrics",
        "include_go_metrics": true
      }
    },
    "message-logger": {
      "name": "message-logger",
      "enabled": true,
      "config": {
        "buffer_size": 10000,
        "monitor_subjects": ["*"],
        "enable_kv_query": true,
        "log_level": "INFO"
      }
    }
  },
  "components": {
    "file_sensors": {
      "type": "input",
      "name": "file_input",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [],
          "outputs": [
            {
              "name": "file_out",
              "subject": "raw.sensor.file",
              "type": "nats"
            }
          ]
        },
        "path": "/data/testdata/tier0/iot-sensors.jsonl",
        "format": "jsonl",
        "interval": "100ms",
        "loop": false
      }
    },
    "udp": {
      "type": "input",
      "name": "udp",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [],
          "outputs": [
            {
              "name": "udp_out",
              "subject": "raw.sensor.udp",
              "type": "nats"
            }
          ]
        },
        "bind": "0.0.0.0",
        "port": 14550,
        "buffer_size": 65536
      }
    },
    "iot_sensor": {
      "type": "processor",
      "name": "iot_sensor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "sensor_in",
              "subject": "raw.sensor.>",
              "type": "nats"
            }
          ],
          "outputs": [
            {
              "name": "sensor_out",
              "subject": "events.graph.entity.sensor",
              "type": "jetstream",
              "interface": "iot.sensor.v1"
            }
          ]
        },
        "org_id": "c360",
        "platform": "logistics"
      }
    },
    "rule": {
      "type": "processor",
      "name": "rule-processor",
      "enabled": true,
      "config": {
        "entity_watch_patterns": ["c360.>"],
        "ports": {
          "inputs": [
            {
              "name": "rule_entity_in",
              "subject": "events.graph.entity.>",
              "type": "nats",
              "description": "Processed entity events with typed BaseMessage payloads"
            }
          ],
          "outputs": [
            {
              "name": "rule_out",
              "subject": "events.rule.triggered",
              "type": "nats"
            }
          ]
        },
        "enable_graph_integration": true,
        "graph_event_subject_prefix": "events.graph.entity",
        "inline_rules": [
          {
            "id": "cold-storage-temp-alert",
            "type": "expression",
            "name": "Cold Storage Temperature Alert",
            "description": "Fires when cold storage temperature exceeds safe threshold (40F). OnEnter creates alert triple, OnExit removes it.",
            "enabled": true,
            "conditions": [
              {
                "field": "sensor.measurement.fahrenheit",
                "operator": "gte",
                "value": 40.0,
                "required": true
              },
              {
                "field": "geo.location.zone",
                "operator": "contains",
                "value": "cold-storage",
                "required": true
              }
            ],
            "logic": "and",
            "cooldown": "5s",
            "on_enter": [
              {
                "type": "add_triple",
                "predicate": "alert.active",
                "object": "cold-storage-violation"
              },
              {
                "type": "publish",
                "subject": "alerts.cold-storage"
              }
            ],
            "on_exit": [
              {
                "type": "remove_triple",
                "predicate": "alert.active",
                "object": "cold-storage-violation"
              },
              {
                "type": "publish",
                "subject": "alerts.cold-storage.cleared"
              }
            ],
            "metadata": {
              "severity": "critical",
              "category": "food_safety",
              "tier": 0
            }
          },
          {
            "id": "high-humidity-alert",
            "type": "expression",
            "name": "High Humidity Alert",
            "description": "Fires when humidity exceeds 50% threshold. Demonstrates stateful rule transitions.",
            "enabled": true,
            "conditions": [
              {
                "field": "sensor.measurement.percent",
                "operator": "gte",
                "value": 50.0,
                "required": true
              },
              {
                "field": "sensor.classification.type",
                "operator": "eq",
                "value": "humidity",
                "required": true
              }
            ],
            "logic": "and",
            "cooldown": "5s",
            "on_enter": [
              {
                "type": "add_triple",
                "predicate": "alert.active",
                "object": "high-humidity-warning"
              },
              {
                "type": "publish",
                "subject": "alerts.humidity"
              }
            ],
            "on_exit": [
              {
                "type": "remove_triple",
                "predicate": "alert.active",
                "object": "high-humidity-warning"
              }
            ],
            "metadata": {
              "severity": "warning",
              "category": "environment",
              "tier": 0
            }
          },
          {
            "id": "low-pressure-alert",
            "type": "expression",
            "name": "Low Air Pressure Alert",
            "description": "Fires when compressed air pressure drops below 100 PSI. OnEnter/OnExit demonstrate dynamic graph state.",
            "enabled": true,
            "conditions": [
              {
                "field": "sensor.measurement.psi",
                "operator": "lt",
                "value": 100.0,
                "required": true
              },
              {
                "field": "sensor.classification.type",
                "operator": "eq",
                "value": "pressure",
                "required": true
              }
            ],
            "logic": "and",
            "cooldown": "5s",
            "on_enter": [
              {
                "type": "add_triple",
                "predicate": "alert.active",
                "object": "low-pressure-warning"
              },
              {
                "type": "publish",
                "subject": "alerts.pressure"
              }
            ],
            "on_exit": [
              {
                "type": "remove_triple",
                "predicate": "alert.active",
                "object": "low-pressure-warning"
              }
            ],
            "metadata": {
              "severity": "warning",
              "category": "equipment",
              "tier": 0
            }
          }
        ]
      }
    },
    "graph": {
      "type": "processor",
      "name": "graph-processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "events_in",
              "subject": "events.graph.entity.>",
              "type": "jetstream",
              "interface": "graph.Entity",
              "description": "Entity events from upstream processors"
            }
          ],
          "outputs": []
        },
        "workers": 4,
        "queue_size": 1000,
        "message_handler": {
          "processing_timeout": "5s",
          "max_retries": 3
        },
        "data_manager": {
          "kv_bucket": "graph_entities_tier0",
          "kv_options": {
            "max_retries": 5,
            "timeout": "5s"
          },
          "enable_edge_tracking": true,
          "edge_batch_size": 50
        },
        "indexer": {
          "indexes": {
            "predicate": true,
            "incoming": true,
            "outgoing": true,
            "alias": true,
            "spatial": true,
            "temporal": true
          },
          "buckets": {
            "alias": "ALIAS_INDEX",
            "predicate": "PREDICATE_INDEX",
            "incoming": "INCOMING_INDEX",
            "outgoing": "OUTGOING_INDEX",
            "spatial": "SPATIAL_INDEX",
            "temporal": "TEMPORAL_INDEX"
          },
          "batch_processing": {
            "size": 50
          },
          "embedding": {
            "enabled": false
          }
        },
        "querier": {
          "cache_enabled": true,
          "cache_ttl": "5m",
          "max_cache_size": 1000,
          "query_timeout": "5s",
          "result_limit": 500
        },
        "clustering": {
          "enabled": false
        },
        "gateway": {
          "graphql": {
            "enabled": true,
            "bind_address": ":8082",
            "path": "/graphql",
            "enable_playground": true,
            "timeout": "30s"
          }
        }
      }
    },
    "file": {
      "type": "output",
      "name": "file",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "file_in",
              "subject": "events.graph.entity.>",
              "type": "nats"
            }
          ],
          "outputs": []
        },
        "directory": "/tmp",
        "file_prefix": "semstreams-tier0-rules",
        "format": "jsonl"
      }
    }
  }
}
