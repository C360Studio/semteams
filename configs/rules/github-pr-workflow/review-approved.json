{
  "id": "review-approved",
  "type": "expression",
  "name": "Review Approved",
  "description": "When reviewer approves the PR, publish completion and mark status completed",
  "enabled": true,
  "entity": {
    "pattern": "*.github.repo.*.workflow.*",
    "watch_buckets": ["ENTITY_STATES"]
  },
  "conditions": [
    {
      "field": "workflow.phase",
      "operator": "eq",
      "value": "approved"
    }
  ],
  "logic": "and",
  "on_enter": [
    {
      "type": "publish",
      "subject": "github.workflow.complete",
      "properties": {
        "reason": "pr_approved"
      }
    },
    {
      "type": "update_triple",
      "predicate": "workflow.status",
      "object": "completed"
    }
  ]
}
