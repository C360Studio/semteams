{
  "id": "budget-exceeded",
  "type": "expression",
  "name": "Budget Exceeded",
  "description": "When total tokens exceed budget and workflow not terminal, escalate and cap iterations",
  "enabled": true,
  "entity": {
    "pattern": "*.github.repo.*.workflow.*",
    "watch_buckets": ["ENTITY_STATES"]
  },
  "conditions": [
    {
      "field": "workflow.tokens.total",
      "operator": "gte",
      "value": 500000
    },
    {
      "field": "workflow.status",
      "operator": "ne",
      "value": "completed"
    },
    {
      "field": "workflow.status",
      "operator": "ne",
      "value": "escalated"
    }
  ],
  "logic": "and",
  "max_iterations": 1,
  "on_enter": [
    {
      "type": "update_triple",
      "predicate": "workflow.phase",
      "object": "escalated"
    },
    {
      "type": "publish",
      "subject": "github.workflow.escalated",
      "properties": {
        "reason": "budget_exceeded"
      }
    }
  ]
}
