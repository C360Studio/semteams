{
  "id": "needs-info",
  "type": "expression",
  "name": "Needs Info",
  "description": "When qualifier determines more information is required, park in awaiting_info",
  "enabled": true,
  "entity": {
    "pattern": "*.github.repo.*.workflow.*",
    "watch_buckets": ["ENTITY_STATES"]
  },
  "conditions": [
    {
      "field": "workflow.phase",
      "operator": "eq",
      "value": "needs_info"
    }
  ],
  "logic": "and",
  "on_enter": [
    {
      "type": "update_triple",
      "predicate": "workflow.phase",
      "object": "awaiting_info"
    }
  ]
}
