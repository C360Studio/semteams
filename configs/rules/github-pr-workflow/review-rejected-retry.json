{
  "id": "review-rejected-retry",
  "type": "expression",
  "name": "Review Rejected - Retry",
  "description": "When reviewer requests changes and retry budget remains, reset phase to developing",
  "enabled": true,
  "entity": {
    "pattern": "*.github.repo.*.workflow.*",
    "watch_buckets": ["ENTITY_STATES"]
  },
  "conditions": [
    {
      "field": "workflow.phase",
      "operator": "eq",
      "value": "changes_requested"
    },
    {
      "field": "workflow.review.rejections",
      "operator": "lt",
      "value": 3
    }
  ],
  "logic": "and",
  "on_enter": [
    {
      "type": "update_triple",
      "predicate": "workflow.phase",
      "object": "developing"
    }
  ]
}
