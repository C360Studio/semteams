{
  "id": "issue-rejected",
  "type": "expression",
  "name": "Issue Rejected",
  "description": "When qualifier deems issue invalid, complete workflow without spawning developer",
  "enabled": true,
  "entity": {
    "pattern": "*.github.repo.*.workflow.*",
    "watch_buckets": ["ENTITY_STATES"]
  },
  "conditions": [
    {
      "field": "workflow.phase",
      "operator": "in",
      "value": ["rejected", "not_a_bug", "wont_fix"]
    }
  ],
  "logic": "and",
  "on_enter": [
    {
      "type": "update_triple",
      "predicate": "workflow.status",
      "object": "completed"
    },
    {
      "type": "publish",
      "subject": "github.workflow.complete",
      "properties": {
        "reason": "issue_rejected"
      }
    }
  ]
}
