{
  "id": "escalate-deadlock",
  "type": "expression",
  "name": "Escalate Deadlock",
  "description": "When reviewer keeps requesting changes and retry budget exhausted, escalate to human",
  "enabled": true,
  "entity": {
    "pattern": "*.github.repo.*.workflow.*",
    "watch_buckets": ["ENTITY_STATES"]
  },
  "conditions": [
    {
      "field": "workflow.phase",
      "operator": "eq",
      "value": "changes_requested"
    },
    {
      "field": "workflow.review.rejections",
      "operator": "gte",
      "value": 3
    }
  ],
  "logic": "and",
  "on_enter": [
    {
      "type": "update_triple",
      "predicate": "workflow.phase",
      "object": "escalated"
    },
    {
      "type": "publish",
      "subject": "github.workflow.escalated",
      "properties": {
        "reason": "review_deadlock"
      }
    }
  ]
}
