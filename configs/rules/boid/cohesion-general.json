{
  "id": "boid_cohesion_general",
  "type": "boid",
  "name": "Agent Cohesion - General Role",
  "description": "Steer general agents toward high-centrality nodes in their work context. Uses PageRank over active subgraph.",
  "enabled": true,
  "entity": {
    "watch_buckets": ["AGENT_POSITIONS"]
  },
  "conditions": [
    {
      "field": "boid.role",
      "operator": "eq",
      "value": "general"
    }
  ],
  "metadata": {
    "boid_rule": "cohesion",
    "role_filter": "general",
    "centrality_weight": 0.7,
    "steering_strength": 0.5,
    "cooldown": "1s"
  },
  "while_true": [
    {
      "type": "publish_boid_signal",
      "subject": "agent.boid.$entity.id",
      "boid_signal_type": "cohesion",
      "boid_strength": 0.5
    }
  ]
}
