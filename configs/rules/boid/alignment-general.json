{
  "id": "boid_alignment_general",
  "type": "boid",
  "name": "Agent Alignment - General Role",
  "description": "Align general agents with same-role traversal patterns. Suggests common predicate paths being followed by peers.",
  "enabled": true,
  "entity": {
    "watch_buckets": ["AGENT_POSITIONS"]
  },
  "conditions": [
    {
      "field": "boid.role",
      "operator": "eq",
      "value": "general"
    }
  ],
  "metadata": {
    "boid_rule": "alignment",
    "role_filter": "general",
    "alignment_window": 5,
    "steering_strength": 0.3,
    "cooldown": "2s"
  },
  "while_true": [
    {
      "type": "publish_boid_signal",
      "subject": "agent.boid.$entity.id",
      "boid_signal_type": "alignment",
      "boid_strength": 0.3
    }
  ]
}
