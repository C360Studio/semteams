{
  "id": "boid_separation_all",
  "type": "boid",
  "name": "Agent Separation - All Roles",
  "description": "Prevent agents from working on overlapping graph neighborhoods. Uses k-hop distance to detect proximity and generates avoid signals.",
  "enabled": true,
  "entity": {
    "watch_buckets": ["AGENT_POSITIONS"]
  },
  "conditions": [],
  "metadata": {
    "boid_rule": "separation",
    "role_thresholds": {
      "general": 2,
      "architect": 3,
      "editor": 2,
      "reviewer": 4
    },
    "steering_strength": 0.8,
    "cooldown": "500ms"
  },
  "while_true": [
    {
      "type": "publish_boid_signal",
      "subject": "agent.boid.$entity.id",
      "boid_signal_type": "separation",
      "boid_strength": 0.8
    }
  ]
}
