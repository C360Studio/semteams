{
  "id": "reviewer-rejected-retry",
  "type": "expression",
  "name": "Reviewer Rejected — Retry Editor",
  "description": "When reviewer rejects and retries remain, re-spawn editor with feedback. TEMPLATE: customize subject, model, and prompt fields in the publish_agent action before enabling.",
  "enabled": false,
  "entity": {
    "pattern": "*.*.*.*.workflow.*",
    "watch_buckets": ["ENTITY_STATES"]
  },
  "conditions": [
    {
      "field": "workflow.role",
      "operator": "eq",
      "value": "reviewer"
    },
    {
      "field": "workflow.outcome",
      "operator": "eq",
      "value": "rejected"
    },
    {
      "field": "$state.iteration",
      "operator": "lt",
      "value": "$state.max_iterations"
    }
  ],
  "logic": "and",
  "max_iterations": 3,
  "on_enter": [
    {
      "type": "publish_agent",
      "role": "editor",
      "properties": {
        "retry": true,
        "reason": "reviewer_rejected"
      }
    },
    {
      "type": "update_triple",
      "predicate": "workflow.phase",
      "object": "editing"
    }
  ]
}
