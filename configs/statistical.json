{
  "version": "1.1.0",
  "platform": {
    "org": "c360",
    "id": "semstreams-kitchen-sink",
    "type": "comprehensive-semantic",
    "region": "local",
    "instance_id": "semantic-999",
    "environment": "test"
  },
  "nats": {
    "urls": ["nats://localhost:4222"]
  },
  "services": {
    "service-manager": {
      "name": "service-manager",
      "enabled": true,
      "config": {
        "http_port": 8080,
        "swagger_ui": true,
        "server_info": {
          "title": "SemStreams Kitchen Sink API",
          "description": "Comprehensive semantic processing with HTTP Gateway",
          "version": "0.7.0"
        }
      }
    },
    "component-manager": {
      "name": "component-manager",
      "enabled": true,
      "config": {}
    },
    "metrics": {
      "name": "metrics",
      "enabled": true,
      "config": {
        "port": 9090,
        "path": "/metrics",
        "include_go_metrics": true
      }
    },
    "message-logger": {
      "name": "message-logger",
      "enabled": true,
      "config": {
        "buffer_size": 10000,
        "monitor_subjects": ["*"],
        "enable_kv_query": true,
        "log_level": "INFO"
      }
    }
  },
  "components": {
    "udp": {
      "type": "input",
      "name": "udp",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [],
          "outputs": [
            {
              "name": "udp_out",
              "subject": "raw.sensor.udp",
              "type": "jetstream"
            }
          ]
        },
        "bind": "0.0.0.0",
        "port": 14550,
        "buffer_size": 65536
      }
    },
    "file_documents": {
      "type": "input",
      "name": "file_input",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [],
          "outputs": [
            {
              "name": "file_out",
              "subject": "raw.document.corpus",
              "type": "jetstream"
            }
          ]
        },
        "path": "/data/testdata/semantic/documents.jsonl",
        "format": "jsonl",
        "interval": "10ms",
        "loop": false
      }
    },
    "file_maintenance": {
      "type": "input",
      "name": "file_input",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [],
          "outputs": [
            {
              "name": "file_out",
              "subject": "raw.document.corpus",
              "type": "jetstream"
            }
          ]
        },
        "path": "/data/testdata/semantic/maintenance.jsonl",
        "format": "jsonl",
        "interval": "10ms",
        "loop": false
      }
    },
    "file_observations": {
      "type": "input",
      "name": "file_input",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [],
          "outputs": [
            {
              "name": "file_out",
              "subject": "raw.document.corpus",
              "type": "jetstream"
            }
          ]
        },
        "path": "/data/testdata/semantic/observations.jsonl",
        "format": "jsonl",
        "interval": "10ms",
        "loop": false
      }
    },
    "file_sensor_docs": {
      "type": "input",
      "name": "file_input",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [],
          "outputs": [
            {
              "name": "file_out",
              "subject": "raw.document.corpus",
              "type": "jetstream"
            }
          ]
        },
        "path": "/data/testdata/semantic/sensor_docs.jsonl",
        "format": "jsonl",
        "interval": "10ms",
        "loop": false
      }
    },
    "file_sensors": {
      "type": "input",
      "name": "file_input",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [],
          "outputs": [
            {
              "name": "file_out",
              "subject": "raw.sensor.file",
              "type": "jetstream"
            }
          ]
        },
        "path": "/data/testdata/semantic/sensors.jsonl",
        "format": "jsonl",
        "interval": "10ms",
        "loop": false
      }
    },
    "document_processor": {
      "type": "processor",
      "name": "document_processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "doc_in",
              "subject": "raw.document.corpus",
              "type": "jetstream"
            }
          ],
          "outputs": [
            {
              "name": "doc_out",
              "subject": "document.processed.entity",
              "type": "jetstream",
              "interface": "content.document.v1"
            }
          ]
        },
        "org_id": "c360",
        "platform": "logistics"
      }
    },
    "iot_sensor": {
      "type": "processor",
      "name": "iot_sensor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "sensor_in",
              "subject": "raw.sensor.>",
              "type": "jetstream"
            }
          ],
          "outputs": [
            {
              "name": "sensor_out",
              "subject": "sensor.processed.entity",
              "type": "jetstream",
              "interface": "iot.sensor.v1"
            }
          ]
        },
        "org_id": "c360",
        "platform": "logistics"
      }
    },
    "rule": {
      "type": "processor",
      "name": "rule-processor",
      "enabled": true,
      "config": {
        "entity_watch_patterns": ["c360.>"],
        "ports": {
          "inputs": [
            {
              "name": "rule_entity_in",
              "subject": "objectstore.stored.entity",
              "type": "jetstream",
              "description": "Stored document entity events"
            },
            {
              "name": "rule_sensor_in",
              "subject": "sensor.processed.entity",
              "type": "jetstream",
              "description": "Sensor entity events (bypass ObjectStore)"
            }
          ],
          "outputs": [
            {
              "name": "rule_out",
              "subject": "rule.triggered.alert",
              "type": "jetstream"
            }
          ]
        },
        "enable_graph_integration": true,
        "graph_event_subject_prefix": "objectstore.stored",
        "inline_rules": [
          {
            "id": "cold-storage-temp-alert",
            "type": "expression",
            "name": "Cold Storage Temperature Alert",
            "description": "Fires when cold storage temperature exceeds safe threshold (40F). OnEnter creates alert triple, OnExit removes it.",
            "enabled": true,
            "conditions": [
              {
                "field": "sensor.measurement.fahrenheit",
                "operator": "gte",
                "value": 40.0,
                "required": true
              },
              {
                "field": "geo.location.zone",
                "operator": "contains",
                "value": "cold-storage",
                "required": true
              }
            ],
            "logic": "and",
            "cooldown": "5s",
            "on_enter": [
              {
                "type": "add_triple",
                "predicate": "alert.active",
                "object": "cold-storage-violation"
              },
              {
                "type": "publish",
                "subject": "alerts.cold-storage"
              }
            ],
            "on_exit": [
              {
                "type": "remove_triple",
                "predicate": "alert.active",
                "object": "cold-storage-violation"
              },
              {
                "type": "publish",
                "subject": "alerts.cold-storage.cleared"
              }
            ],
            "metadata": {
              "severity": "critical",
              "category": "food_safety",
              "tier": 0
            }
          },
          {
            "id": "high-humidity-alert",
            "type": "expression",
            "name": "High Humidity Alert",
            "description": "Fires when humidity exceeds 50% threshold. Demonstrates stateful rule transitions.",
            "enabled": true,
            "conditions": [
              {
                "field": "sensor.measurement.percent",
                "operator": "gte",
                "value": 50.0,
                "required": true
              },
              {
                "field": "sensor.classification.type",
                "operator": "eq",
                "value": "humidity",
                "required": true
              }
            ],
            "logic": "and",
            "cooldown": "5s",
            "on_enter": [
              {
                "type": "add_triple",
                "predicate": "alert.active",
                "object": "high-humidity-warning"
              },
              {
                "type": "publish",
                "subject": "alerts.humidity"
              }
            ],
            "on_exit": [
              {
                "type": "remove_triple",
                "predicate": "alert.active",
                "object": "high-humidity-warning"
              }
            ],
            "metadata": {
              "severity": "warning",
              "category": "environment",
              "tier": 0
            }
          },
          {
            "id": "low-pressure-alert",
            "type": "expression",
            "name": "Low Air Pressure Alert",
            "description": "Fires when compressed air pressure drops below 100 PSI. OnEnter/OnExit demonstrate dynamic graph state.",
            "enabled": true,
            "conditions": [
              {
                "field": "sensor.measurement.psi",
                "operator": "lt",
                "value": 100.0,
                "required": true
              },
              {
                "field": "sensor.classification.type",
                "operator": "eq",
                "value": "pressure",
                "required": true
              }
            ],
            "logic": "and",
            "cooldown": "5s",
            "on_enter": [
              {
                "type": "add_triple",
                "predicate": "alert.active",
                "object": "low-pressure-warning"
              },
              {
                "type": "publish",
                "subject": "alerts.pressure"
              }
            ],
            "on_exit": [
              {
                "type": "remove_triple",
                "predicate": "alert.active",
                "object": "low-pressure-warning"
              }
            ],
            "metadata": {
              "severity": "warning",
              "category": "equipment",
              "tier": 0
            }
          }
        ]
      }
    },
    "graph": {
      "type": "processor",
      "name": "graph-processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "objectstore_in",
              "subject": "objectstore.stored.entity",
              "type": "jetstream",
              "interface": "storage.stored.v1",
              "description": "Stored document entity events from ObjectStore"
            },
            {
              "name": "sensor_in",
              "subject": "sensor.processed.entity",
              "type": "jetstream",
              "interface": "iot.sensor.v1",
              "description": "Sensor entity events from IoT processor"
            }
          ],
          "outputs": []
        },
        "workers": 8,
        "queue_size": 5000,
        "message_handler": {
          "processing_timeout": "5s",
          "max_retries": 5
        },
        "data_manager": {
          "kv_bucket": "ENTITY_STATES",
          "kv_options": {
            "max_retries": 15,
            "timeout": "10s"
          },
          "enable_edge_tracking": true,
          "edge_batch_size": 100
        },
        "indexer": {
          "indexes": {
            "predicate": true,
            "incoming": true,
            "outgoing": true,
            "alias": true,
            "spatial": true,
            "temporal": true,
            "context": true
          },
          "buckets": {
            "alias": "ALIAS_INDEX",
            "predicate": "PREDICATE_INDEX",
            "incoming": "INCOMING_INDEX",
            "outgoing": "OUTGOING_INDEX",
            "spatial": "SPATIAL_INDEX",
            "temporal": "TEMPORAL_INDEX",
            "context": "CONTEXT_INDEX"
          },
          "batch_processing": {
            "size": 50
          },
          "embedding": {
            "enabled": true,
            "content_store_bucket": "semstreams_kitchen_sink_store",
            "text_fields": [
              "dc.terms.title",
              "dc.terms.subject",
              "dc.terms.description",
              "title",
              "description",
              "summary",
              "name",
              "body",
              "content",
              "text",
              "observation.text"
            ]
          }
        },
        "querier": {
          "cache_enabled": true,
          "cache_ttl": "15m",
          "max_cache_size": 5000,
          "query_timeout": "10s",
          "result_limit": 1000
        },
        "graph_analysis": {
          "community_detection": {
            "enabled": true,
            "algorithm": {
              "max_iterations": 100,
              "levels": 3
            },
            "schedule": {
              "initial_delay": "2s",
              "detection_interval": "30s",
              "min_detection_interval": "5s",
              "entity_change_threshold": 100,
              "min_entities": 10,
              "min_embedding_coverage": 0
            },
            "enhancement": {
              "enabled": true,
              "summarizer_endpoint": "http://seminstruct:8083",
              "workers": 3
            },
            "semantic_edges": {
              "enabled": true,
              "similarity_threshold": 0.6,
              "max_virtual_neighbors": 5
            },
            "entityid_edges": {
              "enabled": true,
              "sibling_weight": 0.7,
              "max_siblings": 10,
              "include_siblings": true
            },
            "inference": {
              "enabled": true,
              "min_community_size": 2,
              "max_inferred_per_community": 50
            }
          },
          "structural_index": {
            "enabled": true,
            "compute_on_startup": true,
            "compute_interval": "1h",
            "kcore": {
              "enabled": true,
              "min_core_filter": 0
            },
            "pivot": {
              "enabled": true,
              "pivot_count": 16,
              "max_hop_distance": 10
            }
          },
          "hierarchy_inference": {
            "enabled": true,
            "create_type_edges": true,
            "create_system_edges": true,
            "create_domain_edges": true
          }
        },
        "gateway": {
          "graphql": {
            "enabled": true,
            "bind_address": ":8084",
            "path": "/graphql",
            "enable_playground": true,
            "timeout": "30s"
          }
        }
      }
    },
    "file": {
      "type": "output",
      "name": "file",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "file_in",
              "subject": "objectstore.stored.entity",
              "type": "jetstream",
              "interface": "content.document.v1"
            }
          ],
          "outputs": []
        },
        "directory": "/tmp",
        "file_prefix": "semstreams-kitchen-sink",
        "format": "jsonl"
      }
    },
    "objectstore": {
      "type": "storage",
      "name": "objectstore",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "write",
              "subject": "document.processed.entity",
              "type": "jetstream"
            }
          ],
          "outputs": [
            {
              "name": "stored",
              "subject": "objectstore.stored.entity",
              "type": "jetstream"
            }
          ]
        },
        "bucket_name": "semstreams_kitchen_sink_store",
        "data_cache": {
          "enabled": true,
          "strategy": "hybrid",
          "max_size": 5000,
          "ttl": "1h",
          "cleanup_interval": "5m"
        }
      }
    }
  }
}
