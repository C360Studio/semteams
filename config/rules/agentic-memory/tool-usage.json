{
  "id": "agentic-tool-usage",
  "type": "expression",
  "name": "Track Tool Usage",
  "description": "Track tool invocation patterns during agentic execution. Creates triples recording which tools were used and their frequency.",
  "enabled": true,
  "entity": {
    "pattern": "loop.agentic.task.*",
    "watch_buckets": ["AGENT_LOOPS"]
  },
  "conditions": [
    {
      "field": "tool_calls",
      "operator": "length_gt",
      "value": 0,
      "required": true
    }
  ],
  "logic": "and",
  "cooldown": "0s",
  "while_true": [
    {
      "type": "add_triple",
      "predicate": "agentic.tool.used",
      "object": "$entity.id",
      "ttl": "720h",
      "properties": {
        "source": "rule_engine",
        "extraction_type": "rule_based"
      }
    }
  ],
  "metadata": {
    "category": "agentic-memory",
    "extraction_type": "tool_tracking",
    "adr": "ADR-017"
  }
}
