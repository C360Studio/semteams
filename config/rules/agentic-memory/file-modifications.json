{
  "id": "agentic-file-modified",
  "type": "expression",
  "name": "Extract File Modifications",
  "description": "Extract file modification facts from agent tool results. Creates triples tracking which files were modified, created, or deleted during agentic execution.",
  "enabled": true,
  "entity": {
    "pattern": "loop.agentic.task.*",
    "watch_buckets": ["AGENT_LOOPS"]
  },
  "conditions": [
    {
      "field": "tool_results",
      "operator": "length_gt",
      "value": 0,
      "required": true
    }
  ],
  "logic": "and",
  "cooldown": "0s",
  "on_enter": [
    {
      "type": "add_triple",
      "predicate": "agentic.file.modified",
      "object": "$entity.id",
      "ttl": "720h",
      "properties": {
        "source": "rule_engine",
        "extraction_type": "rule_based"
      }
    }
  ],
  "while_true": [
    {
      "type": "add_triple",
      "predicate": "agentic.tool.file_operation",
      "object": "$entity.id",
      "ttl": "720h",
      "properties": {
        "source": "rule_engine",
        "extraction_type": "rule_based"
      }
    }
  ],
  "metadata": {
    "category": "agentic-memory",
    "extraction_type": "file_tracking",
    "adr": "ADR-017"
  }
}
