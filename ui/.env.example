# Backend Connection
# Point at any running SemStreams app (semstreams, semsource, semmem, etc.)
BACKEND_HOST=localhost:8080

# GraphQL gateway (defaults to BACKEND_HOST if not set)
# GRAPHQL_HOST=localhost:8082

# Server-side backend URL (used by SvelteKit server routes for AI/MCP)
BACKEND_URL=http://localhost:8080

# Development ports
# DEV_UI_PORT=3001
# DEV_VITE_PORT=5173

# E2E Test Port (change to avoid collision with other test suites)
# E2E_UI_PORT=3000

# AI Provider Configuration
# Supports both Anthropic and OpenAI-compatible APIs
#
# Provider: "anthropic" or "openai" (default: anthropic)
AI_PROVIDER=anthropic
#
# Anthropic Configuration
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
#
# OpenAI-Compatible Configuration
# Works with OpenAI, Azure OpenAI, Ollama, vLLM, etc.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1
