# SemTeams Environment Configuration
# Copy to .env and uncomment the variables you need:
#   cp .env.example .env
#
# The Taskfile loads .env automatically (dotenv: ['.env']).
# Docker Compose also loads .env by default.

# ─── LLM Provider Keys ───────────────────────────────────────────────
# The model registry in configs/agentic.json references named endpoints.
# Set API keys here to use cloud LLM providers. The config's model_registry
# reads the URL + model from the JSON; the API key comes from the env.

# Anthropic Claude (used via OpenAI-compatible proxy or native API)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI / OpenRouter (OpenAI-compatible)
# OPENAI_API_KEY=sk-or-...

# Google AI Studio (Gemini) — used via OpenAI-compatible endpoint
# GEMINI_API_KEY=AIza...

# ─── Optional Services ───────────────────────────────────────────────

# Brave Search API — enables the web_search tool for agents
# BRAVE_SEARCH_API_KEY=BSA...

# GitHub — enables github_read/github_write tools
# GITHUB_TOKEN=ghp_...

# ─── Infrastructure ──────────────────────────────────────────────────

# NATS URL (default: nats://localhost:4222)
# Only needed when running the binary outside Docker against a non-default NATS.
# NATS_URL=nats://localhost:4222

# Ollama URL (default: http://localhost:11434)
# For local LLM via Ollama. Inside Docker, compose overrides this to
# http://host.docker.internal:11434.
# LLM_API_URL=http://localhost:11434
#
# Linux + Ollama systemd: Ollama binds 127.0.0.1 by default, blocking
# Docker containers. Fix: sudo systemctl edit ollama → add
#   [Service]
#   Environment="OLLAMA_HOST=0.0.0.0"
# Then: sudo systemctl restart ollama

# ─── Docker Compose ──────────────────────────────────────────────────

# Development ports (avoid collisions with other c360 products)
# DEV_UI_PORT=3001
# DEV_VITE_PORT=5173

# ─── Debugging ────────────────────────────────────────────────────────

# Log level for semteams (debug, info, warn, error)
# LOG_LEVEL=info

# Enable pprof profiling (binds to :6060)
# SEMSTREAMS_DEBUG=true
